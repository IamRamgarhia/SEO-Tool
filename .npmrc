# pnpm config - read by pnpm 11+ on every command.
#
# Why this file exists:
# pnpm 11+ blocks native-module build scripts by default and FAILS the
# install if it sees any package whose post-install script was skipped.
# That makes installs brittle when:
#   - the project adds a new native dep someone forgot to allowlist
#   - a prior failed install left node_modules in a half-built state
#
# Multiple settings used because pnpm has renamed this knob across
# versions (10.x: ignored-builds-fail-install; 11.x: ignored-builds-check;
# some forks: dangerously-allow-all-builds). Setting all three so the
# install works regardless of which pnpm minor version the user has.
ignored-builds-check=false
ignored-builds-fail-install=false
dangerously-allow-all-builds=true
auto-approve-builds=true

# Don't prompt for interactive confirmation when running scripts.
# (Same effect as `pnpm approve-builds --all` but non-interactive.)
confirm-modules-purge=false
